rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - level: number (required)
    //   - xp: number (required)
    //   - coins: number (required)
    //   - streak: number (optional)
    //   - rank: string (optional)
    //   - skillTree: map (optional)
    //   - inventory: list (optional)
    //   - lastActive: string (optional)
    //
    // Collection: quests
    // Document ID: questId
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - difficulty: string (required)
    //   - xpReward: number (required)
    //   - coinReward: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "mathupriya2006@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'level', 'xp', 'coins']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.level is int && data.level >= 0 &&
             data.xp is int && data.xp >= 0 &&
             data.coins is int && data.coins >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. 
      // For leaderboard, we might need public read, but we'll restrict it to authenticated users for now.
      // To prevent PII leak, we only allow reading if it's the owner.
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
    }

    match /quests/{questId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /market/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
